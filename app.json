{
  "expo": {
    "name": "ParaPo",
    "slug": "parapo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1565C0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.parapo.app",
      "infoPlist": {
        "UIBackgroundModes": ["location"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ParaPo shares your location while online so passengers can find you.",
        "NSLocationAlwaysUsageDescription": "ParaPo needs background location so passengers can track you during a ride."
      },
      "config": {
        "googleMapsApiKey": "$(GOOGLE_MAPS_API_KEY_IOS)"
      }
    },
    "android": {
      "package": "com.parapo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1565C0"
      },
      "config": {
        "googleMaps": {
          "apiKey": "$(GOOGLE_MAPS_API_KEY_ANDROID)"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ParaPo needs your location to show nearby tricycles."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1565C0"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
